{
  // Application configuration file.
  // IMPORTANT: Never commit real passwords or connection strings to source control.
  // Use environment variable overrides or User Secrets for sensitive values.
  "ConnectionStrings": {
    // SQL Server connection string — update with your server details
    // For local development with SQL Server Express: "Server=(localdb)\\mssqllocaldb;Database=CorporateMemo;Trusted_Connection=True;"
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=CorporateMemo;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "SmtpSettings": {
    // SMTP server configuration for sending email notifications
    "Host": "smtp.example.com",
    "Port": 587,
    "Username": "noreply@example.com",
    "Password": "CHANGE_ME_USE_ENVIRONMENT_VARIABLE",
    "FromAddress": "noreply@example.com",
    "FromName": "Corporate Memo System",
    "UseSsl": false
  },
  "AttachmentSettings": {
    // File upload configuration
    "UploadPath": "wwwroot/uploads",
    "MaxFileSizeMb": 10,
    "AllowedExtensions": [ "pdf", "docx", "xlsx", "png", "jpg", "jpeg", "gif", "bmp" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
