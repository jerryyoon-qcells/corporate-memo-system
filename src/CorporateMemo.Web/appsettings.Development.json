{
  // Development-specific overrides. These settings are only applied in the Development environment.
  // Set ASPNETCORE_ENVIRONMENT=Development to use this file.
  "ConnectionStrings": {
    // SQLite file-based database — zero install, auto-created on first run.
    // The simple "Data Source=<file>" format (no semicolons) triggers the SQLite
    // code path in InfrastructureServiceExtensions. Production uses SQL Server.
    "DefaultConnection": "Data Source=corporatememo.db"
  },
  "SmtpSettings": {
    // For development, use MailHog (https://github.com/mailhog/MailHog) to capture emails locally
    // Run: docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog
    "Host": "localhost",
    "Port": 1025,
    "Username": "",
    "Password": "",
    "FromAddress": "dev@localhost",
    "FromName": "Corporate Memo System (Dev)",
    "UseSsl": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  }
}
