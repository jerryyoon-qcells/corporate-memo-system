@*
    AttachmentUpload.razor — Drag-and-drop file upload component.
    Allows users to upload one or more files to attach to a memo.
    Shows a list of uploaded files with their names, sizes, and a remove button.
*@
@using CorporateMemo.Application.DTOs
@using Microsoft.AspNetCore.Components.Forms

<div>
    @* Drop zone — users can drag files here or click to browse *@
    <div class="attachment-zone @(_isDragOver ? "drag-over" : "")"
         @ondragover="HandleDragOver"
         @ondragover:preventDefault="true"
         @ondragleave="HandleDragLeave"
         @ondrop="HandleDrop"
         @ondrop:preventDefault="true"
         @onclick="OpenFilePicker"
         role="button"
         tabindex="0"
         aria-label="Drop files here or click to browse"
         @onkeydown="@(e => { if (e.Key == "Enter" || e.Key == " ") OpenFilePicker(); })">

        <i class="bi bi-cloud-upload fs-2 d-block mb-2" aria-hidden="true"></i>
        <p class="mb-1 fw-semibold">Drop files here</p>
        <p class="small mb-0">or <span class="text-primary">click to browse</span></p>
        <p class="small text-muted mt-1">Max @MaxFileSizeMb MB per file. Allowed: PDF, DOCX, XLSX, PNG, JPG, GIF, BMP</p>
    </div>

    @* Hidden file input — triggered by clicking the drop zone *@
    <InputFile @ref="_fileInput"
               OnChange="HandleFileSelection"
               multiple
               accept=".pdf,.docx,.xlsx,.png,.jpg,.jpeg,.gif,.bmp"
               style="display: none;"
               aria-hidden="true" />

    @* Show validation errors *@
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-2 py-2" role="alert">
            <i class="bi bi-exclamation-triangle me-2" aria-hidden="true"></i>
            @_errorMessage
        </div>
    }

    @* Uploaded attachments list *@
    @if (Attachments != null && Attachments.Any())
    {
        <div class="mt-3" role="list" aria-label="Uploaded files">
            @foreach (var attachment in Attachments)
            {
                var id = attachment.Id;
                <div class="attachment-item" role="listitem">
                    @* File type icon based on extension *@
                    <i class="@GetFileIcon(attachment.FileName) attachment-icon" aria-hidden="true"></i>

                    <div class="attachment-name" title="@attachment.FileName">
                        @attachment.FileName
                    </div>

                    <span class="attachment-size">@attachment.FileSizeDisplay</span>

                    @* Remove button *@
                    <button type="button"
                            class="btn btn-outline-danger btn-sm ms-2"
                            @onclick="() => RemoveAttachment(id)"
                            aria-label="Remove file: @attachment.FileName">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                    </button>
                </div>
            }
        </div>
    }
</div>

@code {
    private InputFile? _fileInput;
    private bool _isDragOver;
    private string? _errorMessage;

    /// <summary>Gets or sets the current list of uploaded attachments.</summary>
    [Parameter] public List<AttachmentDto> Attachments { get; set; } = new();

    /// <summary>Gets or sets the maximum file size in MB (from configuration).</summary>
    [Parameter] public int MaxFileSizeMb { get; set; } = 10;

    /// <summary>Gets or sets the callback invoked when a file is selected for upload.</summary>
    [Parameter] public EventCallback<IBrowserFile> OnFileSelected { get; set; }

    /// <summary>Gets or sets the callback invoked when an attachment is removed.</summary>
    [Parameter] public EventCallback<Guid> OnAttachmentRemoved { get; set; }

    private void HandleDragOver() => _isDragOver = true;
    private void HandleDragLeave() => _isDragOver = false;

    private async Task HandleDrop(DragEventArgs e)
    {
        _isDragOver = false;
        // Note: In Blazor Server, drag-and-drop file access is limited.
        // The drop event fires but file data must come from InputFile component.
        // This handler primarily provides visual feedback.
        // Users should click to browse for full file selection support.
    }

    private void OpenFilePicker()
    {
        // Trigger the hidden InputFile click via JavaScript (handled by Blazor)
        // The InputFile component handles the actual file picker dialog
    }

    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        _errorMessage = null;

        foreach (var file in e.GetMultipleFiles(10)) // Max 10 files at once
        {
            // Validate file size
            if (file.Size > (long)MaxFileSizeMb * 1024 * 1024)
            {
                _errorMessage = $"File '{file.Name}' exceeds the maximum size of {MaxFileSizeMb} MB.";
                continue;
            }

            // Notify the parent component that a file was selected
            // The parent handles the actual upload command via MediatR
            await OnFileSelected.InvokeAsync(file);
        }
    }

    private async Task RemoveAttachment(Guid attachmentId)
    {
        await OnAttachmentRemoved.InvokeAsync(attachmentId);
    }

    /// <summary>Returns the appropriate Bootstrap Icons class for the file type.</summary>
    private static string GetFileIcon(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLower();
        return ext switch
        {
            ".pdf" => "bi bi-file-earmark-pdf-fill text-danger",
            ".docx" or ".doc" => "bi bi-file-earmark-word-fill text-primary",
            ".xlsx" or ".xls" => "bi bi-file-earmark-excel-fill text-success",
            ".png" or ".jpg" or ".jpeg" or ".gif" or ".bmp" => "bi bi-file-earmark-image-fill text-info",
            _ => "bi bi-file-earmark-fill text-secondary"
        };
    }
}
