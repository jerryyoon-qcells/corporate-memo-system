@*
    ApproverList.razor — Component for adding and removing approvers from a memo.
    Provides a simple text input for approver email address lookup.
    In a production system, this would have autocomplete from the user database.
*@
@using CorporateMemo.Application.Memos.Commands
@using CorporateMemo.Domain.Entities
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

<div>
    @* Current approvers list *@
    @if (Approvers.Any())
    {
        <ul class="list-group mb-3" role="list" aria-label="Assigned approvers">
            @{
                var approverIndex = 0;
            }
            @foreach (var approver in Approvers)
            {
                var currentApprover = approver;
                var index = approverIndex;
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-person-check me-2 text-success" aria-hidden="true"></i>
                        <strong>@approver.DisplayName</strong>
                        <small class="text-muted ms-2">@approver.Email</small>
                    </div>
                    <button type="button"
                            class="btn btn-outline-danger btn-sm"
                            @onclick="() => RemoveApprover(currentApprover)"
                            aria-label="Remove approver: @approver.DisplayName">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                    </button>
                </li>
                approverIndex++;
            }
        </ul>
    }
    else
    {
        <p class="text-muted small fst-italic mb-3">
            No approvers assigned. Submit will auto-publish the memo.
        </p>
    }

    @* Add approver by name or email *@
    <UserAutocomplete Placeholder="Search approver by name or email..."
                      ExcludedEmails="@(Approvers.Select(a => a.Email))"
                      OnUserSelected="OnApproverUserSelected" />

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="text-danger small mt-1">
            <i class="bi bi-exclamation-circle me-1"></i>@_errorMessage
        </div>
    }
</div>

@code {
    private string? _errorMessage;

    /// <summary>Gets or sets the current list of approvers.</summary>
    [Parameter] public List<ApproverInfo> Approvers { get; set; } = new();

    /// <summary>Gets or sets the callback invoked when the approver list changes.</summary>
    [Parameter] public EventCallback<List<ApproverInfo>> ApproversChanged { get; set; }

    private async Task OnApproverUserSelected(ApplicationUser user)
    {
        _errorMessage = null;

        // Only Admin or Collaborator users can approve memos
        var roles = await UserManager.GetRolesAsync(user);
        if (!roles.Any(r => r == "Admin" || r == "Collaborator"))
        {
            _errorMessage = $"'{user.DisplayName}' has the Viewer role and cannot be assigned as an approver. Only Admin or Collaborator users may approve memos.";
            return;
        }

        // Duplicate guard (UserAutocomplete ExcludedEmails handles most cases,
        // but UserId is the authoritative check)
        if (Approvers.Any(a => a.UserId == user.Id))
        {
            _errorMessage = "This user is already in the approver list.";
            return;
        }

        var newApprovers = new List<ApproverInfo>(Approvers)
        {
            new ApproverInfo
            {
                UserId = user.Id,
                DisplayName = user.DisplayName,
                Email = user.Email ?? string.Empty
            }
        };

        await ApproversChanged.InvokeAsync(newApprovers);
    }

    private async Task RemoveApprover(ApproverInfo approver)
    {
        var newApprovers = new List<ApproverInfo>(Approvers);
        newApprovers.Remove(approver);
        await ApproversChanged.InvokeAsync(newApprovers);
    }
}
