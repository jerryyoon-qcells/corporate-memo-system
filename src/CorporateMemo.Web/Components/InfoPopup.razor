@*
    InfoPopup.razor — Click-triggered info popup that auto-dismisses after 5 seconds.

    Usage:
        <InfoPopup Text="Your explanation text here." />

    Clicking the (i) icon shows the popup above the icon.
    It disappears automatically after 5 seconds, or immediately on a second click.
*@

<span class="info-popup-wrapper">
    <button type="button"
            class="info-popup-trigger"
            @onclick="TogglePopup"
            aria-label="More information"
            aria-expanded="@_visible">
        <i class="bi bi-info-circle" aria-hidden="true"></i>
    </button>

    @if (_visible)
    {
        <div class="info-popup-box" role="tooltip" aria-live="polite">
            @Text
        </div>
    }
</span>

@code {
    /// <summary>The explanation text shown in the popup.</summary>
    [Parameter] public string Text { get; set; } = string.Empty;

    private bool _visible;
    private CancellationTokenSource? _cts;

    private async Task TogglePopup()
    {
        // Second click while visible — dismiss immediately
        if (_visible)
        {
            _cts?.Cancel();
            _visible = false;
            return;
        }

        // Show the popup and start the 5-second auto-hide timer
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        _visible = true;

        try
        {
            await Task.Delay(5000, _cts.Token);
            _visible = false;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // Dismissed early by a second click — nothing to do
        }
    }
}
