@*
    Login.cshtml — Razor Page login form.

    WHY A RAZOR PAGE INSTEAD OF A BLAZOR COMPONENT?
    Blazor Server runs over a persistent SignalR WebSocket connection.
    By the time a user clicks a button in a Blazor component, the original
    HTTP response has already been sent and its headers are sealed.
    Setting an authentication cookie requires writing to HTTP response headers,
    so it MUST happen during a real HTTP request — not over SignalR.
    Razor Pages run on the normal HTTP pipeline, so they can set cookies.
*@
@page "/login"
@model CorporateMemo.Web.Pages.LoginPageModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Corporate Memo System</title>
    <!-- Bootstrap 5 for styling — matches the rest of the application -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          crossorigin="anonymous" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="bg-light">

    <!-- Vertically and horizontally centred login card -->
    <div class="min-vh-100 d-flex align-items-center justify-content-center">
        <div class="card shadow-sm" style="width: 100%; max-width: 420px;">
            <div class="card-body p-4 p-sm-5">

                <!-- Branding -->
                <div class="text-center mb-4">
                    <i class="bi bi-file-earmark-text-fill text-primary" style="font-size: 3rem;"></i>
                    <h1 class="fs-3 fw-bold mt-2">Corporate Memo System</h1>
                    <p class="text-muted small">Sign in to your account</p>
                </div>

                <!-- Error alert — shown when credentials are wrong or account is locked -->
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <span>@Model.ErrorMessage</span>
                    </div>
                }

                <!--
                    Standard HTML form — posts to this same page via HTTP POST.
                    The PageModel's OnPostAsync handler processes the credentials,
                    calls SignInManager, sets the auth cookie, and redirects.
                    asp-antiforgery="true" adds the hidden CSRF token automatically.
                -->
                <form method="post" asp-antiforgery="true">

                    <!-- Email field -->
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold">
                            Email address <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.Email"
                               class="form-control @(ViewData.ModelState["Input.Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               type="email"
                               placeholder="you@company.com"
                               autocomplete="email"
                               autofocus />
                        <span asp-validation-for="Input.Email" class="invalid-feedback"></span>
                    </div>

                    <!-- Password field -->
                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label fw-semibold">
                            Password <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.Password"
                               class="form-control @(ViewData.ModelState["Input.Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               type="password"
                               placeholder="Enter your password"
                               autocomplete="current-password" />
                        <span asp-validation-for="Input.Password" class="invalid-feedback"></span>
                    </div>

                    <!-- Hidden field carries the return URL through the POST -->
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

                    <!-- Submit button -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            Sign In
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>

</body>
</html>
