@*
    UserManagement.razor — Admin-only page for managing system users.
    Allows creating, enabling/disabling, resetting passwords, force-logging out, and deleting users.
    Only accessible to users with the Admin role.
*@
@page "/admin/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using CorporateMemo.Application.Interfaces
@using CorporateMemo.Domain.Entities
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject ICurrentUserService CurrentUserService
@inject ILogger<UserManagement> Logger

<PageTitle>User Management — Corporate Memo System</PageTitle>

@* Page header *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">User Management</li>
            </ol>
        </nav>
        <h1 class="fs-2 fw-bold text-dark mb-0">User Management</h1>
    </div>
    <button class="btn btn-primary" @onclick="ToggleCreateForm">
        <i class="bi bi-person-plus-fill me-2" aria-hidden="true"></i>
        @(_showCreateForm ? "Cancel" : "New User")
    </button>
</div>

@* Alert banners *@
@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success alert-dismissible d-flex align-items-center" role="alert">
        <i class="bi bi-check-circle-fill me-2" aria-hidden="true"></i>
        @_successMessage
        <button type="button" class="btn-close ms-auto" @onclick="() => _successMessage = null" aria-label="Close"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
        @_errorMessage
    </div>
}

@* Create user form (collapsible) *@
@if (_showCreateForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-primary text-white fw-semibold">
            <i class="bi bi-person-plus-fill me-2" aria-hidden="true"></i>Create New User
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(_createError))
            {
                <div class="alert alert-danger py-2">
                    <i class="bi bi-exclamation-circle me-1" aria-hidden="true"></i>@_createError
                </div>
            }
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Display Name <span class="text-danger" aria-hidden="true">*</span>
                    </label>
                    <input type="text" class="form-control" @bind="_newDisplayName"
                           placeholder="Full name" maxlength="256" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Email Address <span class="text-danger" aria-hidden="true">*</span>
                    </label>
                    <input type="email" class="form-control" @bind="_newEmail"
                           placeholder="user@company.com" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Department</label>
                    <input type="text" class="form-control" @bind="_newDepartment"
                           placeholder="e.g. Finance" maxlength="100"
                           autocomplete="off" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Role <span class="text-danger" aria-hidden="true">*</span>
                    </label>
                    <select class="form-select" @bind="_newRole">
                        <option value="">-- Select Role --</option>
                        @foreach (var r in _availableRoles)
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Password <span class="text-danger" aria-hidden="true">*</span>
                    </label>
                    <div class="input-group">
                        <input type="@(_showPassword ? "text" : "password")" class="form-control"
                               @bind="_newPassword" placeholder="Min 8 chars, 1 digit" />
                        <button type="button" class="btn btn-outline-secondary"
                                @onclick="TogglePasswordVisibility"
                                title="@(_showPassword ? "Hide password" : "Show password")"
                                aria-label="@(_showPassword ? "Hide password" : "Show password")">
                            <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")" aria-hidden="true"></i>
                        </button>
                    </div>
                    <small class="text-muted">Must be at least 8 characters with at least 1 digit.</small>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-primary" @onclick="CreateUserAsync" disabled="@_isLoading">
                    <i class="bi bi-person-check-fill me-1" aria-hidden="true"></i>Create User
                </button>
                <button class="btn btn-outline-secondary" @onclick="ToggleCreateForm">Cancel</button>
            </div>
        </div>
    </div>
}

@* User table *@
@if (_isLoading && !_users.Any())
{
    <div class="text-center py-5" aria-live="polite">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading users...</span>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" aria-label="User list">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Email</th>
                            <th scope="col">Department</th>
                            <th scope="col">Role</th>
                            <th scope="col">Status</th>
                            <th scope="col"><span class="visually-hidden">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _users)
                        {
                            <tr>
                                <td class="fw-semibold">@user.DisplayName</td>
                                <td class="text-muted small">@user.Email</td>
                                <td>@(string.IsNullOrEmpty(user.Department) ? "—" : user.Department)</td>
                                <td>
                                    <span class="badge @GetRoleBadgeClass(user.Role)">@user.Role</span>
                                </td>
                                <td>
                                    @if (user.IsLockedOut)
                                    {
                                        <span class="badge bg-danger">Locked</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                </td>
                                <td>
                                    @* Show generated temp password once after a reset *@
                                    @if (!string.IsNullOrEmpty(user.TempPassword))
                                    {
                                        <div class="alert alert-warning py-1 px-2 small mb-1 d-flex align-items-center gap-2" role="alert">
                                            <i class="bi bi-key" aria-hidden="true"></i>
                                            Temp: <strong>@user.TempPassword</strong>
                                            <button class="btn-close btn-close-sm ms-auto" style="font-size:0.6rem;"
                                                    @onclick="() => user.TempPassword = null"
                                                    aria-label="Dismiss temp password"></button>
                                        </div>
                                    }
                                    <div class="d-flex gap-1 flex-wrap">
                                        @* Enable (shown only when locked) *@
                                        @if (user.IsLockedOut)
                                        {
                                            <button class="btn btn-sm btn-outline-success"
                                                    title="Enable account"
                                                    @onclick="() => EnableUserAsync(user)">
                                                <i class="bi bi-person-check" aria-hidden="true"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            @* Disable (shown when active; disabled for own account) *@
                                            <button class="btn btn-sm btn-outline-warning"
                                                    title="Disable account"
                                                    disabled="@IsCurrentUser(user)"
                                                    @onclick="() => ShowDisableConfirm(user)">
                                                <i class="bi bi-person-slash" aria-hidden="true"></i>
                                            </button>
                                        }
                                        @* Reset Password *@
                                        <button class="btn btn-sm btn-outline-secondary"
                                                title="Reset password"
                                                @onclick="() => ResetPasswordAsync(user)">
                                            <i class="bi bi-key" aria-hidden="true"></i>
                                        </button>
                                        @* Force Logout (disabled for own account) *@
                                        <button class="btn btn-sm btn-outline-secondary"
                                                title="Force logout — invalidates all active sessions"
                                                disabled="@IsCurrentUser(user)"
                                                @onclick="() => ShowForceLogoutConfirm(user)">
                                            <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                                        </button>
                                        @* Delete (disabled for own account) *@
                                        <button class="btn btn-sm btn-outline-danger"
                                                title="Delete user"
                                                disabled="@IsCurrentUser(user)"
                                                @onclick="() => ShowDeleteConfirm(user)">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!_users.Any())
                {
                    <div class="text-center text-muted py-4">No users found.</div>
                }
            </div>
        </div>
    </div>
}

@* Confirmation dialogs *@
<ConfirmDialog @ref="_deleteDialog"
               Title="Delete User"
               Message="@($"Permanently delete '{_pendingUser?.DisplayName}'? This cannot be undone.")"
               ConfirmText="Delete"
               ConfirmClass="btn-danger"
               OnConfirmed="ExecuteDeleteAsync" />

<ConfirmDialog @ref="_disableDialog"
               Title="Disable Account"
               Message="@($"Disable '{_pendingUser?.DisplayName}'s account? They will be locked out immediately.")"
               ConfirmText="Disable"
               ConfirmClass="btn-warning"
               OnConfirmed="ExecuteDisableAsync" />

<ConfirmDialog @ref="_forceLogoutDialog"
               Title="Force Logout"
               Message="@($"Invalidate all active sessions for '{_pendingUser?.DisplayName}'? They will be logged out immediately.")"
               ConfirmText="Force Logout"
               ConfirmClass="btn-secondary"
               OnConfirmed="ExecuteForceLogoutAsync" />

@code {
    // -------------------------------------------------------------------------
    // Inner model — one row in the user table
    // -------------------------------------------------------------------------
    private class UserRow
    {
        public string Id { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string? Department { get; set; }
        public string Role { get; set; } = string.Empty;
        public bool IsLockedOut { get; set; }
        public string? TempPassword { get; set; }   // shown once after a password reset
    }

    // -------------------------------------------------------------------------
    // Page state
    // -------------------------------------------------------------------------
    private List<UserRow> _users = new();
    private List<string> _availableRoles = new();
    private bool _isLoading;
    private string? _successMessage;
    private string? _errorMessage;

    // Create form
    private bool _showCreateForm;
    private string _newDisplayName = string.Empty;
    private string _newEmail = string.Empty;
    private string _newDepartment = string.Empty;
    private string _newPassword = string.Empty;
    private string _newRole = string.Empty;
    private string? _createError;

    // Password visibility toggle
    private bool _showPassword;
    private CancellationTokenSource? _pwVisibilityCts;

    // Pending action target (for confirmation dialogs)
    private UserRow? _pendingUser;

    // Confirmation dialog refs
    private ConfirmDialog _deleteDialog = default!;
    private ConfirmDialog _disableDialog = default!;
    private ConfirmDialog _forceLogoutDialog = default!;

    // -------------------------------------------------------------------------
    // Initialisation
    // -------------------------------------------------------------------------
    protected override async Task OnInitializedAsync()
    {
        _availableRoles = await RoleManager.Roles
            .Select(r => r.Name!)
            .OrderBy(n => n)
            .ToListAsync();
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            var appUsers = await UserManager.Users.ToListAsync();
            var rows = new List<UserRow>(appUsers.Count);
            foreach (var u in appUsers)
            {
                var roles = await UserManager.GetRolesAsync(u);
                rows.Add(new UserRow
                {
                    Id          = u.Id,
                    DisplayName = u.DisplayName,
                    Email       = u.Email ?? string.Empty,
                    Department  = u.Department,
                    Role        = roles.FirstOrDefault() ?? "None",
                    IsLockedOut = await UserManager.IsLockedOutAsync(u)
                });
            }
            _users = rows;
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to load users.";
            Logger.LogError(ex, "Error loading user list");
        }
        finally
        {
            _isLoading = false;
        }
    }

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------
    private bool IsCurrentUser(UserRow row) =>
        row.Email.Equals(CurrentUserService.UserEmail, StringComparison.OrdinalIgnoreCase);

    private static string GetRoleBadgeClass(string role) => role switch
    {
        "Admin"        => "bg-danger",
        "Collaborator" => "bg-primary",
        "Viewer"       => "bg-secondary",
        _              => "bg-light text-dark"
    };

    private void ToggleCreateForm()
    {
        _showCreateForm = !_showCreateForm;
        _newDisplayName = _newEmail = _newDepartment = _newPassword = _newRole = string.Empty;
        _createError = null;
        _showPassword = false;
        _pwVisibilityCts?.Cancel();
    }

    private async Task TogglePasswordVisibility()
    {
        _pwVisibilityCts?.Cancel();

        if (_showPassword)
        {
            _showPassword = false;
            return;
        }

        // Show password and auto-hide after 5 seconds
        _pwVisibilityCts = new CancellationTokenSource();
        _showPassword = true;

        try
        {
            await Task.Delay(5000, _pwVisibilityCts.Token);
            _showPassword = false;
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    // -------------------------------------------------------------------------
    // Create User
    // -------------------------------------------------------------------------
    private async Task CreateUserAsync()
    {
        _createError = null;
        if (string.IsNullOrWhiteSpace(_newDisplayName) ||
            string.IsNullOrWhiteSpace(_newEmail) ||
            string.IsNullOrWhiteSpace(_newPassword) ||
            string.IsNullOrWhiteSpace(_newRole))
        {
            _createError = "Display Name, Email, Password and Role are all required.";
            return;
        }

        var user = new ApplicationUser
        {
            UserName       = _newEmail,
            Email          = _newEmail,
            DisplayName    = _newDisplayName.Trim(),
            Department     = string.IsNullOrWhiteSpace(_newDepartment) ? null : _newDepartment.Trim(),
            EmailConfirmed = true,
            LockoutEnabled = true
        };

        var createResult = await UserManager.CreateAsync(user, _newPassword);
        if (!createResult.Succeeded)
        {
            _createError = string.Join(" ", createResult.Errors.Select(e => e.Description));
            return;
        }

        await UserManager.AddToRoleAsync(user, _newRole);
        _successMessage = $"User '{user.DisplayName}' created successfully.";
        _showCreateForm = false;
        _newDisplayName = _newEmail = _newDepartment = _newPassword = _newRole = string.Empty;
        await LoadUsersAsync();
    }

    // -------------------------------------------------------------------------
    // Enable Account
    // -------------------------------------------------------------------------
    private async Task EnableUserAsync(UserRow row)
    {
        var user = await UserManager.FindByIdAsync(row.Id);
        if (user is null) return;
        await UserManager.SetLockoutEndDateAsync(user, null);
        _successMessage = $"'{row.DisplayName}' has been enabled.";
        await LoadUsersAsync();
    }

    // -------------------------------------------------------------------------
    // Disable Account (with confirmation)
    // -------------------------------------------------------------------------
    private void ShowDisableConfirm(UserRow row)
    {
        _pendingUser = row;
        _disableDialog.Show();
    }

    private async Task ExecuteDisableAsync()
    {
        if (_pendingUser is null) return;
        var user = await UserManager.FindByIdAsync(_pendingUser.Id);
        if (user is not null)
        {
            await UserManager.SetLockoutEndDateAsync(user, DateTimeOffset.MaxValue);
            _successMessage = $"'{_pendingUser.DisplayName}' has been disabled.";
        }
        _pendingUser = null;
        await LoadUsersAsync();
    }

    // -------------------------------------------------------------------------
    // Reset Password
    // -------------------------------------------------------------------------
    private async Task ResetPasswordAsync(UserRow row)
    {
        var user = await UserManager.FindByIdAsync(row.Id);
        if (user is null) return;

        // Generate temp password that satisfies the configured policy:
        // RequireDigit=true, RequiredLength=8, RequireUppercase=false
        var tempPassword = $"Tmp{new Random().Next(100000, 999999)}";

        var token  = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, tempPassword);

        if (result.Succeeded)
        {
            // Surface the temp password inline; the admin communicates it to the user
            var target = _users.FirstOrDefault(u => u.Id == row.Id);
            if (target is not null) target.TempPassword = tempPassword;
            _successMessage = $"Password for '{row.DisplayName}' has been reset.";
        }
        else
        {
            _errorMessage = "Password reset failed: " +
                string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }

    // -------------------------------------------------------------------------
    // Force Logout (with confirmation)
    // -------------------------------------------------------------------------
    private void ShowForceLogoutConfirm(UserRow row)
    {
        _pendingUser = row;
        _forceLogoutDialog.Show();
    }

    private async Task ExecuteForceLogoutAsync()
    {
        if (_pendingUser is null) return;
        var user = await UserManager.FindByIdAsync(_pendingUser.Id);
        if (user is not null)
        {
            // Updating the SecurityStamp invalidates all existing auth cookies for this user.
            // Their next request will fail the cookie stamp validation and force a re-login.
            await UserManager.UpdateSecurityStampAsync(user);
            Logger.LogInformation("Admin force-logged-out user {UserId}", user.Id);
            _successMessage = $"All sessions for '{_pendingUser.DisplayName}' have been invalidated.";
        }
        _pendingUser = null;
    }

    // -------------------------------------------------------------------------
    // Delete User (with confirmation)
    // -------------------------------------------------------------------------
    private void ShowDeleteConfirm(UserRow row)
    {
        _pendingUser = row;
        _deleteDialog.Show();
    }

    private async Task ExecuteDeleteAsync()
    {
        if (_pendingUser is null) return;
        var user = await UserManager.FindByIdAsync(_pendingUser.Id);
        if (user is not null)
        {
            var result = await UserManager.DeleteAsync(user);
            if (result.Succeeded)
                _successMessage = $"User '{_pendingUser.DisplayName}' has been deleted.";
            else
                _errorMessage = "Delete failed: " +
                    string.Join(", ", result.Errors.Select(e => e.Description));
        }
        _pendingUser = null;
        await LoadUsersAsync();
    }
}
