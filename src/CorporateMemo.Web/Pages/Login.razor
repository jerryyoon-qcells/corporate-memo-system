@*
    Login.razor — The login page for the Corporate Memo System.
    Handles user authentication using ASP.NET Core Identity's SignInManager.
    After successful login, redirects to the requested URL (or dashboard).
*@
@* Route removed — login is now the Razor Page Login.cshtml.
   Blazor components cannot set HTTP cookies (response already committed over SignalR).
   See Login.cshtml / Login.cshtml.cs for the working implementation. *@
@page "/login-blazor-disabled"
@layout CorporateMemo.Web.Components.MainLayout
@using CorporateMemo.Domain.Entities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@inject ILogger<Login> Logger

@* Skip the sidebar for the login page — full-width centered layout *@
<PageTitle>Sign In — Corporate Memo System</PageTitle>

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="card shadow-sm" style="width: 100%; max-width: 420px;">
        <div class="card-body p-4 p-sm-5">
            @* Logo/branding *@
            <div class="text-center mb-4">
                <i class="bi bi-file-earmark-text-fill text-primary" style="font-size: 3rem;" aria-hidden="true"></i>
                <h1 class="fs-3 fw-bold mt-2">Corporate Memo System</h1>
                <p class="text-muted">Sign in to your account</p>
            </div>

            @* Error message (wrong password, locked account, etc.) *@
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle me-2" aria-hidden="true"></i>
                    @_errorMessage
                </div>
            }

            @* Login form *@
            <EditForm Model="_loginModel" OnValidSubmit="HandleLogin" aria-label="Login form">
                <DataAnnotationsValidator />

                @* Email field *@
                <div class="mb-3">
                    <label for="email" class="form-label fw-semibold">
                        Email address <span class="required-indicator" aria-hidden="true">*</span>
                    </label>
                    <input id="email"
                           type="email"
                           class="form-control"
                           @bind="_loginModel.Email"
                           @bind:event="oninput"
                           placeholder="you@company.com"
                           autocomplete="email"
                           required
                           aria-required="true" />
                </div>

                @* Password field *@
                <div class="mb-4">
                    <label for="password" class="form-label fw-semibold">
                        Password <span class="required-indicator" aria-hidden="true">*</span>
                    </label>
                    <input id="password"
                           type="password"
                           class="form-control"
                           @bind="_loginModel.Password"
                           @bind:event="oninput"
                           placeholder="Enter your password"
                           autocomplete="current-password"
                           required
                           aria-required="true" />
                </div>

                @* Submit button *@
                <div class="d-grid">
                    <button type="submit"
                            class="btn btn-primary btn-lg"
                            disabled="@_isLoading">
                        @if (_isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Signing in...</span>
                        }
                        else
                        {
                            <span>Sign In</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    // Simple model class for the login form fields
    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private readonly LoginModel _loginModel = new();
    private string? _errorMessage;
    private bool _isLoading;

    /// <summary>Gets or sets the URL to redirect to after successful login (from query string).</summary>
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            // Attempt to sign in with the provided credentials
            var result = await SignInManager.PasswordSignInAsync(
                _loginModel.Email,
                _loginModel.Password,
                isPersistent: false,  // Session cookie (not persistent)
                lockoutOnFailure: true);

            if (result.Succeeded)
            {
                Logger.LogInformation("User {Email} logged in successfully", _loginModel.Email);

                // Redirect to the requested URL or the dashboard
                var redirectUrl = ReturnUrl ?? "/";
                // Use forceLoad: true so the browser fully reloads with the auth cookie
                Nav.NavigateTo(redirectUrl, forceLoad: true);
            }
            else if (result.IsLockedOut)
            {
                _errorMessage = "Your account has been locked due to too many failed login attempts. Please try again in 15 minutes.";
                Logger.LogWarning("Account locked for user {Email}", _loginModel.Email);
            }
            else
            {
                _errorMessage = "Invalid email or password. Please check your credentials and try again.";
                Logger.LogWarning("Failed login attempt for {Email}", _loginModel.Email);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "An unexpected error occurred. Please try again later.";
            Logger.LogError(ex, "Unexpected error during login for {Email}", _loginModel.Email);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
